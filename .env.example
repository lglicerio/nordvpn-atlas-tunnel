# Copy to `.env` and fill in.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# NordVPN *service* credentials -- NOT your NordVPN account login.
#
# Where to find them:
#   https://my.nordaccount.com/  ->  NordVPN  ->  Set up NordVPN manually
#   ->  Service credentials (manual setup)
# These are auto-generated by NordVPN; the username looks like a long
# random string, the password is a separate random string.
# ---------------------------------------------------------------------------
NORDVPN_USER=
NORDVPN_PASSWORD=

# ---------------------------------------------------------------------------
# Hostname of YOUR dedicated-IP server.
#
# Pull it from the .ovpn file you downloaded for the dedicated IP -- look
# for the `remote <hostname> <port>` line near the top, e.g.:
#     remote us9999.nordvpn.com 1194
# Use just the hostname here.
#
# If you have multiple dedicated IPs, list them comma-separated.
# ---------------------------------------------------------------------------
NORDVPN_SERVER=

TZ=Europe/London

# ---------------------------------------------------------------------------
# Optional SOCKS5 auth -- uncomment matching block in docker-compose.yml too.
# ---------------------------------------------------------------------------
# SOCKS_USER=
# SOCKS_PASSWORD=
